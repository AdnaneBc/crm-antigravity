generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                     String                   @id @default(cuid())
  name                   String
  isActive               Boolean                  @default(true)
  suspendedAt            DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  logoUrl                String?
  primaryColor           String?
  secondaryColor         String?
  doctors                Doctor[]
  OrganizationUser       OrganizationUser[]
  PromotionalItem        PromotionalItem[]
  Sector                 Sector[]
  StockAllocation        StockAllocation[]
  Team                   Team[]
  visits                 Visit[]
  VisitDistribution      VisitDistribution[]
  OrganizationSubscription OrganizationSubscription[]
  Invoice                Invoice[]
  AuditLog               AuditLog[]
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  passwordHash     String
  firstName        String
  lastName         String
  isActive         Boolean            @default(true)
  platformRole     PlatformRole?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  address          String?
  phone            String?
  profileImageUrl  String?
  OrganizationUser OrganizationUser[]
  AuditLog         AuditLog[]
}

model Doctor {
  id             String       @id @default(cuid())
  firstName      String
  lastName       String
  speciality     String?
  type           DoctorType
  sectorId       String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  address        String?
  phone          String?
  city           String?
  sectorName     String?
  sectorIMS      String?
  gamme          String?
  potential      String?
  lap            String?
  code           String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  Sector         Sector?      @relation(fields: [sectorId], references: [id])
  visits         Visit[]
}

model Visit {
  id                String              @id @default(cuid())
  organizationId    String
  doctorId          String
  delegateId        String
  visitedAt         DateTime
  status            VisitStatus         @default(PENDING_VALIDATION)
  notes             String?
  description       String?
  nextVisitDate     DateTime?
  completedAt       DateTime?
  validatedById     String?
  validatedAt       DateTime?
  rejectionReason   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  OrganizationUser  OrganizationUser    @relation(fields: [delegateId], references: [id])
  doctor            Doctor              @relation(fields: [doctorId], references: [id])
  organization      Organization        @relation(fields: [organizationId], references: [id])
  VisitDistribution VisitDistribution[]
}

model OrganizationUser {
  id                                    String             @id
  userId                                String
  organizationId                        String
  organizationRole                      OrganizationRole   @default(MEMBER)
  businessRole                          BusinessRole?
  managerId                             String?
  teamId                                String?
  isActive                              Boolean            @default(true)
  createdAt                             DateTime           @default(now())
  updatedAt                             DateTime
  fullName                              String?
  gender                                String?
  phone                                 String?
  city                                  String?
  gamme                                 String?
  assignedSectors                       String[]           @default([])
  OrganizationUser                      OrganizationUser?  @relation("OrganizationUserToOrganizationUser", fields: [managerId], references: [id])
  other_OrganizationUser                OrganizationUser[] @relation("OrganizationUserToOrganizationUser")
  Organization                          Organization       @relation(fields: [organizationId], references: [id])
  Team_OrganizationUser_teamIdToTeam    Team?              @relation("OrganizationUser_teamIdToTeam", fields: [teamId], references: [id])
  User                                  User               @relation(fields: [userId], references: [id])
  Sector                                Sector[]
  StockAllocation                       StockAllocation[]
  Team_Team_managerIdToOrganizationUser Team[]             @relation("Team_managerIdToOrganizationUser")
  Visit                                 Visit[]

  @@unique([userId, organizationId])
}

model PromotionalItem {
  id                String              @id
  organizationId    String
  name              String
  description       String?
  type              PromoItemType
  gamme             String?
  totalStock        Int                 @default(0)
  minStockLevel     Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  Organization      Organization        @relation(fields: [organizationId], references: [id])
  StockAllocation   StockAllocation[]
  VisitDistribution VisitDistribution[]
}

model Sector {
  id               String           @id
  name             String
  organizationId   String
  managerId        String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  Doctor           Doctor[]
  OrganizationUser OrganizationUser @relation(fields: [managerId], references: [id])
  Organization     Organization     @relation(fields: [organizationId], references: [id])
}

model StockAllocation {
  id               String           @id
  organizationId   String
  itemId           String
  delegateId       String
  quantity         Int
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  OrganizationUser OrganizationUser @relation(fields: [delegateId], references: [id])
  PromotionalItem  PromotionalItem  @relation(fields: [itemId], references: [id])
  Organization     Organization     @relation(fields: [organizationId], references: [id])
}

model Team {
  id                                                String             @id
  name                                              String
  organizationId                                    String
  managerId                                         String
  createdAt                                         DateTime           @default(now())
  updatedAt                                         DateTime
  OrganizationUser_OrganizationUser_teamIdToTeam    OrganizationUser[] @relation("OrganizationUser_teamIdToTeam")
  OrganizationUser_Team_managerIdToOrganizationUser OrganizationUser   @relation("Team_managerIdToOrganizationUser", fields: [managerId], references: [id])
  Organization                                      Organization       @relation(fields: [organizationId], references: [id])
}

model VisitDistribution {
  id              String          @id
  organizationId  String
  visitId         String
  itemId          String
  quantity        Int
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  PromotionalItem PromotionalItem @relation(fields: [itemId], references: [id])
  Organization    Organization    @relation(fields: [organizationId], references: [id])
  Visit           Visit           @relation(fields: [visitId], references: [id])

  @@unique([visitId, itemId])
}

// ── Billing & Subscriptions ───────────────────────────────────────────────────

model SubscriptionPlan {
  id                     String                   @id @default(cuid())
  name                   String
  description            String?
  price                  Float
  interval               BillingInterval          @default(MONTHLY)
  maxUsers               Int                      @default(50)
  maxDoctors             Int                      @default(500)
  features               String[]                 @default([])
  isActive               Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  OrganizationSubscription OrganizationSubscription[]
}

model OrganizationSubscription {
  id             String             @id @default(cuid())
  organizationId String
  planId         String
  status         SubscriptionStatus @default(ACTIVE)
  startDate      DateTime
  endDate        DateTime?
  trialEndsAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  Organization   Organization       @relation(fields: [organizationId], references: [id])
  Plan           SubscriptionPlan   @relation(fields: [planId], references: [id])
  Invoice        Invoice[]
}

model Invoice {
  id             String                    @id @default(cuid())
  organizationId String
  subscriptionId String
  amount         Float
  currency       String                    @default("EUR")
  status         InvoiceStatus             @default(PENDING)
  dueDate        DateTime
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  Organization   Organization              @relation(fields: [organizationId], references: [id])
  Subscription   OrganizationSubscription  @relation(fields: [subscriptionId], references: [id])
}

// ── Audit Log ─────────────────────────────────────────────────────────────────

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String?
  userId         String
  action         String
  resource       String
  resourceId     String?
  meta           Json?
  createdAt      DateTime     @default(now())
  Organization   Organization? @relation(fields: [organizationId], references: [id])
  User           User          @relation(fields: [userId], references: [id])
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum BusinessRole {
  NSM
  DSM
  DELEGATE
  ASSISTANT
}

enum DoctorType {
  PUBLIC
  PRIVATE
  CHU
}

enum OrganizationRole {
  ADMIN
  MEMBER
}

enum PlatformRole {
  SUPER_ADMIN
}

enum VisitStatus {
  PENDING_VALIDATION
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum PromoItemType {
  EMG
  GADGET
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}
