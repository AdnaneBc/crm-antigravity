generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                String              @id @default(cuid())
  name              String
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  logoUrl           String?
  primaryColor      String?
  secondaryColor    String?
  doctors           Doctor[]
  OrganizationUser  OrganizationUser[]
  PromotionalItem   PromotionalItem[]
  Sector            Sector[]
  StockAllocation   StockAllocation[]
  Team              Team[]
  visits            Visit[]
  VisitDistribution VisitDistribution[]
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  passwordHash     String
  name             String
  isActive         Boolean            @default(true)
  platformRole     PlatformRole?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  address          String?
  phone            String?
  profileImageUrl  String?
  OrganizationUser OrganizationUser[]
}

model Doctor {
  id             String       @id @default(cuid())
  firstName      String
  lastName       String
  speciality     String?
  type           DoctorType
  sectorId       String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  address        String?
  phone          String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  Sector         Sector?      @relation(fields: [sectorId], references: [id])
  visits         Visit[]
}

model Visit {
  id                String              @id @default(cuid())
  organizationId    String
  doctorId          String
  delegateId        String
  visitedAt         DateTime
  status            VisitStatus         @default(PLANNED)
  notes             String? // planning notes
  description       String? // report: what happened
  nextVisitDate     DateTime? // report: next planned visit
  completedAt       DateTime? // set when report submitted
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  OrganizationUser  OrganizationUser    @relation(fields: [delegateId], references: [id])
  doctor            Doctor              @relation(fields: [doctorId], references: [id])
  organization      Organization        @relation(fields: [organizationId], references: [id])
  VisitDistribution VisitDistribution[]
}

model OrganizationUser {
  id                                    String             @id
  userId                                String
  organizationId                        String
  organizationRole                      OrganizationRole   @default(MEMBER)
  businessRole                          BusinessRole?
  managerId                             String?
  teamId                                String?
  isActive                              Boolean            @default(true)
  createdAt                             DateTime           @default(now())
  updatedAt                             DateTime
  OrganizationUser                      OrganizationUser?  @relation("OrganizationUserToOrganizationUser", fields: [managerId], references: [id])
  other_OrganizationUser                OrganizationUser[] @relation("OrganizationUserToOrganizationUser")
  Organization                          Organization       @relation(fields: [organizationId], references: [id])
  Team_OrganizationUser_teamIdToTeam    Team?              @relation("OrganizationUser_teamIdToTeam", fields: [teamId], references: [id])
  User                                  User               @relation(fields: [userId], references: [id])
  Sector                                Sector[]
  StockAllocation                       StockAllocation[]
  Team_Team_managerIdToOrganizationUser Team[]             @relation("Team_managerIdToOrganizationUser")
  Visit                                 Visit[]

  @@unique([userId, organizationId])
}

model PromotionalItem {
  id                String              @id
  organizationId    String
  name              String
  type              PromoItemType
  totalStock        Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  Organization      Organization        @relation(fields: [organizationId], references: [id])
  StockAllocation   StockAllocation[]
  VisitDistribution VisitDistribution[]
}

model Sector {
  id               String           @id
  name             String
  organizationId   String
  managerId        String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  Doctor           Doctor[]
  OrganizationUser OrganizationUser @relation(fields: [managerId], references: [id])
  Organization     Organization     @relation(fields: [organizationId], references: [id])
}

model StockAllocation {
  id               String           @id
  organizationId   String
  itemId           String
  delegateId       String
  quantity         Int
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  OrganizationUser OrganizationUser @relation(fields: [delegateId], references: [id])
  PromotionalItem  PromotionalItem  @relation(fields: [itemId], references: [id])
  Organization     Organization     @relation(fields: [organizationId], references: [id])
}

model Team {
  id                                                String             @id
  name                                              String
  organizationId                                    String
  managerId                                         String
  createdAt                                         DateTime           @default(now())
  updatedAt                                         DateTime
  OrganizationUser_OrganizationUser_teamIdToTeam    OrganizationUser[] @relation("OrganizationUser_teamIdToTeam")
  OrganizationUser_Team_managerIdToOrganizationUser OrganizationUser   @relation("Team_managerIdToOrganizationUser", fields: [managerId], references: [id])
  Organization                                      Organization       @relation(fields: [organizationId], references: [id])
}

model VisitDistribution {
  id              String          @id
  organizationId  String
  visitId         String
  itemId          String
  quantity        Int
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  PromotionalItem PromotionalItem @relation(fields: [itemId], references: [id])
  Organization    Organization    @relation(fields: [organizationId], references: [id])
  Visit           Visit           @relation(fields: [visitId], references: [id])

  @@unique([visitId, itemId])
}

enum BusinessRole {
  NSM
  DSM
  DELEGATE
  ASSISTANT
}

enum DoctorType {
  PUBLIC
  PRIVATE
  CHU
}

enum OrganizationRole {
  ADMIN
  MEMBER
}

enum PlatformRole {
  SUPER_ADMIN
}

enum VisitStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

enum PromoItemType {
  SAMPLE
  EMG
  GADGET
}
